<%
/**
 * Toast Alert Component
 * @param {string} type - 'destructive', 'success', 'warning', 'info'
 * @param {string} title - Alert title
 * @param {string} message - Alert message
 */
const alertType = locals.type || 'info';
const alertTitle = locals.title || 'Notification';
const alertMessage = locals.message || '';
const toastId = 'toast-' + Math.random().toString(36).substr(2, 9);
%>

<div class="toast toast-<%= alertType %>" id="<%= toastId %>" role="alert" aria-live="polite">
  <div class="toast-icon">
    <% if (alertType === 'destructive') { %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <line x1="12" y1="8" x2="12" y2="12" />
        <line x1="12" y1="16" x2="12.01" y2="16" />
      </svg>
    <% } else if (alertType === 'success') { %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
        <polyline points="22 4 12 14.01 9 11.01" />
      </svg>
    <% } else if (alertType === 'warning') { %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
        <line x1="12" y1="9" x2="12" y2="13" />
        <line x1="12" y1="17" x2="12.01" y2="17" />
      </svg>
    <% } else { %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <line x1="12" y1="16" x2="12" y2="12" />
        <line x1="12" y1="8" x2="12.01" y2="8" />
      </svg>
    <% } %>
  </div>
  <div class="toast-content">
    <h4><%= alertTitle %></h4>
    <p><%= alertMessage %></p>
  </div>
  <button class="toast-close" onclick="dismissToast('<%= toastId %>')" aria-label="Tutup">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>
  <div class="toast-progress"></div>
</div>

<script>
(function() {
  var id = '<%= toastId %>';
  var duration = <%= (alertType === 'destructive') ? 6000 : 4500 %>;

  if (!window.dismissToast) {
    window.dismissToast = function(toastId) {
      var el = document.getElementById(toastId);
      if (!el) return;
      el.classList.add('toast-hiding');
      setTimeout(function() { if (el) el.remove(); }, 400);
    };
  }

  setTimeout(function() { window.dismissToast(id); }, duration);

  var el = document.getElementById(id);
  if (el) {
    var bar = el.querySelector('.toast-progress');
    if (bar) {
      bar.style.transition = 'width ' + duration + 'ms linear';
      setTimeout(function() { bar.style.width = '0%'; }, 50);
    }
    setTimeout(function() { el.classList.add('toast-visible'); }, 10);
  }
})();
</script>
