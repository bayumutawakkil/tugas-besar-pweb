<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<div class="max-w-4xl mx-auto">

  <%- include('../partials/_breadcrumb', {
    items: [
      { label: 'Data Penelitian', href: '/penelitian/my-penelitian' },
      { label: 'Detail Penelitian', href: '/penelitian/' + penelitian.id },
      { label: 'Kelola Anggota' }
    ]
  }) %>

  <%- include('../partials/_form-errors') %>

  <div class="card-premium p-6 sm:p-8 mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h2 class="text-xl font-bold text-slate-900 m-0 tracking-tight">Kelola Anggota</h2>
      <p class="text-sm text-slate-500 mt-1 mb-0">
        Penelitian: <strong class="text-slate-700 font-semibold"><%= penelitian.judul %></strong>
      </p>
    </div>
    <%- include('../partials/_badge-status', { status: penelitian.status }) %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
    
    <!-- Form Tambah Anggota (KOLOM KIRI di Desktop) -->
    <div class="lg:col-span-1">
      <div class="card-premium p-6">
        <h3 class="text-base font-bold text-slate-900 mb-4 border-b border-slate-100 pb-3">Tambah Anggota</h3>
        <form method="POST" action="/penelitian/<%= penelitian.id %>/anggota/add" class="flex flex-col gap-4">
          <div>
            <label for="dosen_id" class="block text-sm font-semibold text-slate-900 mb-1.5">Pilih Dosen</label>
            <select id="dosen_id" name="dosen_id" class="form-select" required>
              <option value="">-- Pilih Dosen --</option>
              <% availableDosen.forEach(d => { %>
                <option value="<%= d.id %>"><%= d.name %> (<%= d.email %>)</option>
              <% }) %>
            </select>
          </div>
          <button type="submit" class="btn btn-gradient w-full" <%= availableDosen.length === 0 ? 'disabled' : '' %>>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
            Tambahkan Anggota
          </button>
        </form>
        <% if (availableDosen.length === 0) { %>
          <div class="mt-4 p-3 bg-slate-50 border border-slate-100 rounded-lg flex items-start gap-2 text-sm text-slate-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-slate-400"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Semua dosen sudah terdaftar di penelitian ini.
          </div>
        <% } %>
      </div>
    </div>

    <!-- Daftar Anggota (KOLOM KANAN di Desktop) -->
    <div class="lg:col-span-2">
      <div class="card-premium overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
          <h3 class="text-base font-bold text-slate-900 m-0">Daftar Anggota</h3>
          <span class="text-xs font-semibold text-slate-500 bg-white border border-slate-200 px-2 py-1 rounded shadow-sm"><%= anggotaList.length %> Orang</span>
        </div>

        <% if (anggotaList.length === 0) { %>
          <div class="p-10 text-center text-slate-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-3 text-slate-300"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Belum ada anggota terdaftar.
          </div>
        <% } else { %>
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-slate-50/50 border-b border-slate-200 text-xs uppercase tracking-wider text-slate-500 font-semibold">
                  <th class="py-3 px-6">Nama & Email</th>
                  <th class="py-3 px-6 text-center">Peran</th>
                  <th class="py-3 px-6 text-center">Status</th>
                  <th class="py-3 px-6 text-center w-24">Aksi</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 text-sm">
                <% anggotaList.forEach(a => { %>
                  <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="py-3 px-6">
                      <div class="font-semibold text-slate-900"><%= a.dosen_name || '-' %></div>
                      <div class="text-xs text-slate-500 mt-0.5"><%= a.dosen_email || '-' %></div>
                    </td>
                    <td class="py-3 px-6 text-center">
                      <span class="<%= a.role === 'Ketua' ? 'badge-role-ketua' : 'badge-role-anggota' %>">
                        <%= a.role %>
                      </span>
                    </td>
                    <td class="py-3 px-6 text-center">
                      <% if (a.status === 'approved') { %>
                        <span class="badge-status-aktif">Diterima</span>
                      <% } else if (a.status === 'rejected') { %>
                        <span class="badge-status-ditolak">Ditolak</span>
                      <% } else { %>
                        <span class="badge-pending">Menunggu</span>
                      <% } %>
                    </td>
                    <td class="py-3 px-6 text-center">
                      <% if (a.role !== 'Ketua') { %>
                        <form method="POST" action="/penelitian/<%= penelitian.id %>/anggota/remove" onsubmit="return confirm('Hapus anggota <%= a.dosen_name %>?')" class="m-0">
                          <input type="hidden" name="dosen_id" value="<%= a.dosen_id %>">
                          <button type="submit" class="inline-flex items-center justify-center px-2 py-1.5 text-xs font-semibold text-red-600 bg-white border border-red-200 rounded hover:bg-red-50 transition-colors shadow-sm" title="Hapus Anggota">
                            Hapus
                          </button>
                        </form>
                      <% } else { %>
                        <span class="text-slate-300 font-medium" title="Ketua tidak bisa dihapus">Ketua</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

</div>

<%- include('../partials/footer') %>
