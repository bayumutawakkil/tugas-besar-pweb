<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_page-header', {
  title: 'Data Penelitian Saya',
  subtitle: 'Penelitian yang Anda kelola sebagai ketua atau anggota',
  toolbar: 'penelitian-mine',
  pendingInvites: pendingInvites
}) %>

<%- include('../partials/_search-bar', {
  action: '/penelitian/search',
  placeholder: 'Cari di penelitian saya...',
  hidden: { scope: 'mine' }
}) %>

<% if (Array.isArray(pendingInvites) && pendingInvites.length > 0) { %>
  <div class="card-premium p-6 mb-6 border-amber-200 bg-amber-50/50">
    <div class="flex items-start gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500 shrink-0 mt-0.5"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <div class="flex-1 min-w-0">
        <h2 class="text-lg font-bold text-slate-900 m-0">Undangan Penelitian</h2>
        <p class="text-sm text-slate-600 mt-1 mb-4">Penelitian yang menunggu konfirmasi Anda.</p>
        <div class="card-premium overflow-hidden">
          <div class="overflow-x-auto">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Judul</th>
                  <th class="text-center">Ketua</th>
                  <th class="text-center">Status</th>
                  <th class="text-center w-32">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% pendingInvites.forEach((p) => { %>
                  <tr>
                    <td class="font-semibold">
                      <a href="/penelitian/<%= p.id %>" class="text-blue-600 hover:text-blue-800"><%= p.judul %></a>
                    </td>
                    <td class="text-center text-slate-700"><%= p.ketua_name || '-' %></td>
                    <td class="text-center"><span class="badge-pending">Menunggu</span></td>
                    <td class="text-center">
                      <a href="/penelitian/<%= p.id %>" class="btn-detail">Lihat & Proses</a>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
<% } %>

<div class="card-premium overflow-hidden">
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th class="text-center w-12">No</th>
          <th>Judul Penelitian</th>
          <th class="text-center">Tahun</th>
          <th class="text-center">Peran Saya</th>
          <th class="text-center">Status</th>
          <th class="text-center w-48">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (penelitianList.length === 0) { %>
          <%- include('../partials/_empty-state', {
            colspan: 6,
            title: 'Belum ada data penelitian',
            message: 'Anda belum memiliki penelitian. <a href="/penelitian/create" class="text-blue-600 font-semibold">Tambah sekarang &rarr;</a>',
            ctaHref: '/penelitian/create',
            ctaLabel: 'Tambah Penelitian'
          }) %>
        <% } else { %>
          <% penelitianList.forEach((p, i) => {
               const isKetua = Number(p.ketua_id) === Number(user.id);
          %>
            <tr class="group">
              <td class="text-center text-slate-500"><%= i + 1 %></td>
              <td>
                <a href="/penelitian/<%= p.id %>" class="font-semibold text-blue-600 hover:text-blue-800 block mb-1"><%= p.judul %></a>
                <div class="text-xs text-slate-500">Ketua: <span class="font-medium text-slate-700"><%= p.ketua_name || '-' %></span></div>
              </td>
              <td class="text-center text-slate-700">
                <%= p.tahun_mulai %><% if (p.tahun_selesai) { %>–<%= p.tahun_selesai %><% } %>
              </td>
              <td class="text-center">
                <span class="<%= isKetua ? 'badge-role-ketua' : 'badge-role-anggota' %>">
                  <%= isKetua ? 'Ketua' : (p.my_role || 'Anggota') %>
                </span>
              </td>
              <td class="text-center">
                <%- include('../partials/_badge-status', { status: p.status }) %>
              </td>
              <td class="text-center">
                <div class="flex flex-wrap items-center justify-center gap-2">
                  <a href="/penelitian/<%= p.id %>" class="btn-icon" title="Detail">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                  <% if (isKetua) { %>
                    <a href="/penelitian/<%= p.id %>/anggota" class="btn-icon" title="Kelola Anggota">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                    </a>
                    <a href="/penelitian/<%= p.id %>/edit" class="btn-icon" title="Ubah">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </a>
                    <button type="button" class="btn-icon text-red-600 border-red-200 hover:bg-red-50" title="Hapus" onclick="confirmDelete('<%= p.id %>', '<%= p.judul.replace(/'/g, "\\'") %>')">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                    </button>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/_modal-delete') %>
<%- include('../partials/footer') %>
