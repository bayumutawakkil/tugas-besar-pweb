<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_page-header', {
  title: 'Undangan Penelitian',
  subtitle: 'Konfirmasi undangan keanggotaan penelitian dari dosen lain',
  badge: pendingInvites.length > 0
    ? '<span class="inline-flex items-center rounded-full bg-red-500 px-3 py-1 text-xs font-bold text-white">' + pendingInvites.length + ' menunggu</span>'
    : '<span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Tidak ada undangan</span>'
}) %>

<% if (!Array.isArray(pendingInvites) || pendingInvites.length === 0) { %>
  <div class="card-premium overflow-hidden">
    <%- include('../partials/_empty-state', {
      inCard: false,
      title: 'Tidak ada undangan',
      message: 'Anda belum menerima undangan penelitian. Undangan baru akan muncul di halaman ini.',
      ctaHref: '/penelitian/my-penelitian',
      ctaLabel: 'Lihat Penelitian Saya'
    }) %>
  </div>
<% } else { %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <% pendingInvites.forEach(function(p) { %>
      <article class="card-premium overflow-hidden flex flex-col">
        <div class="p-6 border-b border-slate-100 bg-gradient-to-r from-indigo-50/80 to-blue-50/50">
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <span class="badge-pending mb-3 inline-block">Menunggu Konfirmasi</span>
              <h2 class="text-lg font-bold text-slate-900 m-0 leading-snug">
                <a href="/penelitian/<%= p.id %>" class="text-blue-700 hover:text-blue-900"><%= p.judul %></a>
              </h2>
            </div>
          </div>
        </div>

        <div class="p-6 flex-1 flex flex-col gap-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-slate-500 mb-1">Ketua Penelitian</p>
              <p class="font-semibold text-slate-900 m-0"><%= p.ketua_name || '-' %></p>
              <p class="text-slate-500 text-xs mt-0.5 m-0"><%= p.ketua_email || '' %></p>
            </div>
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-slate-500 mb-1">Periode</p>
              <p class="font-semibold text-slate-900 m-0">
                <%= p.tahun_mulai %><% if (p.tahun_selesai) { %> – <%= p.tahun_selesai %><% } %>
              </p>
            </div>
          </div>

          <% if (p.deskripsi) { %>
            <div>
              <p class="text-xs font-bold uppercase tracking-wide text-slate-500 mb-1">Deskripsi</p>
              <p class="text-sm text-slate-600 m-0 line-clamp-3"><%= p.deskripsi %></p>
            </div>
          <% } %>

          <div class="mt-auto pt-4 border-t border-slate-100 flex flex-col sm:flex-row gap-3">
            <form method="POST" action="/penelitian/<%= p.id %>/membership/update" class="m-0 flex-1">
              <input type="hidden" name="status" value="approved">
              <button type="submit" class="btn btn-gradient w-full">Terima Undangan</button>
            </form>
            <form method="POST" action="/penelitian/<%= p.id %>/membership/update" class="m-0 flex-1" onsubmit="return confirm('Tolak undangan penelitian ini?')">
              <input type="hidden" name="status" value="rejected">
              <button type="submit" class="btn btn-danger w-full">Tolak</button>
            </form>
            <a href="/penelitian/<%= p.id %>" class="btn btn-secondary w-full sm:w-auto text-center">Detail</a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
