<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_page-header', {
  title: 'Semua Data Penelitian',
  subtitle: 'Daftar seluruh penelitian yang terdaftar di FTI',
  toolbar: 'penelitian-all'
}) %>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="card-premium p-4 text-center">
    <p class="text-3xl font-black text-slate-900 m-0"><%= stats.total %></p>
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mt-1">Total</p>
  </div>
  <div class="card-premium p-4 text-center">
    <p class="text-3xl font-black text-blue-600 m-0"><%= stats.aktif %></p>
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mt-1">Aktif</p>
  </div>
  <div class="card-premium p-4 text-center">
    <p class="text-3xl font-black text-emerald-600 m-0"><%= stats.selesai %></p>
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mt-1">Selesai</p>
  </div>
  <div class="card-premium p-4 text-center">
    <p class="text-3xl font-black text-slate-500 m-0"><%= stats.draft %></p>
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mt-1">Draft</p>
  </div>
</div>

<%- include('../partials/_search-bar', {
  action: '/penelitian/search',
  placeholder: 'Cari judul, deskripsi, atau nama ketua...',
  hidden: { scope: 'all' }
}) %>

<div class="card-premium overflow-hidden">
  <div class="overflow-x-auto">
    <table class="data-table">
      <thead>
        <tr>
          <th class="text-center w-12">No</th>
          <th>Judul Penelitian</th>
          <th>Ketua</th>
          <th class="text-center">Tahun</th>
          <th class="text-center">Anggota</th>
          <th class="text-center">Status</th>
          <th class="text-center w-28">Aksi</th>
        </tr>
      </thead>
      <tbody>
        <% if (penelitianList.length === 0) { %>
          <%- include('../partials/_empty-state', {
            colspan: 7,
            title: 'Belum ada data penelitian',
            message: (typeof user !== 'undefined' && user.role === 'admin') ? 'Sistem belum memiliki data penelitian yang terdaftar.' : 'Mulai dengan menambahkan penelitian baru.',
            ctaHref: (typeof user !== 'undefined' && user.role === 'admin') ? null : '/penelitian/create',
            ctaLabel: (typeof user !== 'undefined' && user.role === 'admin') ? null : 'Tambah Penelitian'
          }) %>
        <% } else { %>
          <% penelitianList.forEach((p, i) => { %>
            <tr>
              <td class="text-center text-slate-500"><%= i + 1 %></td>
              <td class="wrap-text">
                <a href="/penelitian/<%= p.id %>" class="font-semibold text-blue-600 hover:text-blue-800 transition-colors">
                  <%= p.judul %>
                </a>
              </td>
              <td class="text-slate-700 font-medium"><%= p.ketua_name || '-' %></td>
              <td class="text-center text-slate-600">
                <span class="year-badge">
                  <%= p.tahun_mulai %><% if (p.tahun_selesai) { %>–<%= p.tahun_selesai %><% } %>
                </span>
              </td>
              <td class="text-center text-slate-700"><%= p.total_anggota || 0 %></td>
              <td class="text-center">
                <%- include('../partials/_badge-status', { status: p.status }) %>
              </td>
              <td class="text-center">
                <a href="/penelitian/<%= p.id %>" class="btn-detail">Detail</a>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>
