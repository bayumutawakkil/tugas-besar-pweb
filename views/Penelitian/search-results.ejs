<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_page-header', {
  title: 'Hasil Pencarian',
  subtitle: 'Kata kunci: "' + keyword + '"' + (scope === 'mine' ? ' (hanya penelitian saya)' : '') + ' — ditemukan ' + penelitianList.length + ' hasil'
}) %>

<%- include('../partials/_search-bar', {
  action: '/penelitian/search',
  placeholder: 'Cari ulang...',
  value: keyword,
  submitLabel: 'Cari Ulang',
  showScope: true,
  scope: scope,
  resetHref: '/penelitian/dashboard'
}) %>

<% if (penelitianList.length === 0) { %>
  <%- include('../partials/_empty-state', {
    title: 'Pencarian Tidak Ditemukan',
    message: 'Tidak ada penelitian yang cocok dengan kata kunci <strong class="text-slate-700">"' + keyword + '"</strong>. Coba kata kunci lain.',
    ctaHref: '/penelitian/dashboard',
    ctaLabel: 'Kembali ke Daftar'
  }) %>
<% } else { %>
  <div class="card-premium overflow-hidden">
    <div class="overflow-x-auto">
      <table class="data-table">
        <thead>
          <tr>
            <th class="text-center w-12">No</th>
            <th>Judul Penelitian</th>
            <th>Ketua</th>
            <th class="text-center">Tahun</th>
            <th class="text-center">Anggota</th>
            <th class="text-center">Status</th>
            <th class="text-center w-24">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% penelitianList.forEach((p, i) => { %>
            <tr>
              <td class="text-center text-slate-500"><%= i + 1 %></td>
              <td>
                <a href="/penelitian/<%= p.id %>" class="font-semibold text-blue-600 hover:text-blue-800 leading-snug block">
                  <% const re = new RegExp('(' + keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi'); %>
                  <%- p.judul.replace(re, '<mark class="bg-yellow-200 text-slate-900 rounded-sm px-0.5">$1</mark>') %>
                </a>
              </td>
              <td class="text-slate-700"><%= p.ketua_name || '-' %></td>
              <td class="text-center text-slate-700">
                <%= p.tahun_mulai %><% if (p.tahun_selesai) { %>–<%= p.tahun_selesai %><% } %>
              </td>
              <td class="text-center text-slate-700"><%= p.total_anggota || 0 %></td>
              <td class="text-center">
                <%- include('../partials/_badge-status', { status: p.status }) %>
              </td>
              <td class="text-center">
                <a href="/penelitian/<%= p.id %>" class="btn-detail">Detail</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
