<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<div class="max-w-2xl mx-auto">

  <%- include('../partials/_breadcrumb', {
    items: [
      { label: 'Data Penelitian', href: '/penelitian/my-penelitian' },
      { label: 'Detail Penelitian', href: '/penelitian/' + penelitian.id },
      { label: 'Ubah Penelitian' }
    ]
  }) %>

  <div class="card-premium overflow-hidden mb-10">
    <div class="form-card-header">
      <h2>Ubah Penelitian</h2>
      <p>Perbarui informasi penelitian. Kolom bertanda <span class="text-red-500 font-semibold">*</span> wajib diisi.</p>
    </div>

    <div class="px-6 pt-6">
    <%- include('../partials/_form-errors') %>
    </div>

    <form method="POST" action="/penelitian/<%= penelitian.id %>/update" novalidate class="p-6 pt-0">

      <div class="form-group">
        <label for="judul" class="form-label">Judul Penelitian <span class="text-red-500">*</span></label>
        <input type="text" id="judul" name="judul" class="form-input" maxlength="500" required value="<%= penelitian.judul || '' %>">
        <span class="form-hint">Maksimal 500 karakter.</span>
      </div>

      <div class="form-group">
        <label for="deskripsi" class="form-label">Deskripsi / Abstrak</label>
        <textarea id="deskripsi" name="deskripsi" class="form-textarea" rows="4"><%= penelitian.deskripsi || '' %></textarea>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <div class="form-group mb-0">
          <label for="tahun_mulai" class="form-label">Tahun Mulai <span class="text-red-500">*</span></label>
          <input type="number" id="tahun_mulai" name="tahun_mulai" class="form-input" min="2000" max="<%= new Date().getFullYear() + 5 %>" required value="<%= penelitian.tahun_mulai || '' %>">
        </div>
        <div class="form-group mb-0">
          <label for="tahun_selesai" class="form-label">Tahun Selesai</label>
          <input type="number" id="tahun_selesai" name="tahun_selesai" class="form-input" min="2000" max="<%= new Date().getFullYear() + 10 %>" placeholder="(opsional)" value="<%= penelitian.tahun_selesai || '' %>">
        </div>
      </div>

      <div class="form-group">
        <label for="status" class="form-label">Status</label>
        <select id="status" name="status" class="form-select">
          <% const statusLabels = { draft: 'Draft', aktif: 'Aktif', selesai: 'Selesai', ditolak: 'Ditolak' };
             ['draft','aktif','selesai','ditolak'].forEach(s => { %>
            <option value="<%= s %>" <%= penelitian.status === s ? 'selected' : '' %>><%= statusLabels[s] %></option>
          <% }); %>
        </select>
      </div>

      <%- include('../partials/_form-actions', {
        submitLabel: 'Perbarui Penelitian',
        cancelHref: '/penelitian/' + penelitian.id
      }) %>

    </form>
  </div>
</div>

<%- include('../partials/footer') %>
