<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_breadcrumb', {
  items: [
    { label: 'Kelola Pengguna', href: '/auth/users' },
    { label: 'Detail Pengguna' }
  ]
}) %>

<%- include('../partials/_page-header', {
  title: 'Detail Pengguna',
  subtitle: 'ID #' + detailUser.id + ' · Terdaftar sejak ' + (detailUser.created_at ? new Date(detailUser.created_at).toLocaleDateString('id-ID', { day:'2-digit', month:'long', year:'numeric' }) : '-')
}) %>

<div class="grid gap-6 max-w-3xl">

  <div class="card-premium p-6">
    <h3 class="text-lg font-semibold text-slate-900 mb-5 border-b border-slate-100 pb-3">Informasi Akun</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-5 gap-x-8 text-sm">
      <div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Nama</div>
        <div class="font-medium text-slate-900 text-base"><%= detailUser.name %></div>
      </div>
      <div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Email</div>
        <div class="text-slate-700 text-base"><%= detailUser.email %></div>
      </div>
      <div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Peran</div>
        <div class="mt-1">
          <span class="<%= detailUser.role === 'admin' ? 'badge-role-ketua' : 'badge-role-anggota' %> capitalize"><%= detailUser.role %></span>
        </div>
      </div>
      <div>
        <div class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Status</div>
        <div class="mt-1">
          <% if (detailUser.status === 'aktif') { %>
            <span class="badge-status-aktif">Aktif</span>
          <% } else { %>
            <span class="badge-status-ditolak">Nonaktif</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  
  <div class="card-premium p-6">
    <h3 class="text-lg font-semibold text-slate-900 mb-5 border-b border-slate-100 pb-3">Ubah Nama & Email</h3>
    <form action="/auth/users/<%= detailUser.id %>/edit" method="POST" class="space-y-4">
      <%- include('../partials/_input', {
        inputType: 'text',
        inputId: 'edit-name',
        inputName: 'name',
        inputLabel: 'Nama',
        inputValue: detailUser.name,
        inputRequired: true
      }) %>
      <%- include('../partials/_input', {
        inputType: 'email',
        inputId: 'edit-email',
        inputName: 'email',
        inputLabel: 'Email',
        inputValue: detailUser.email,
        inputRequired: true
      }) %>
      <button type="submit" class="btn btn-gradient mt-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
        Simpan Perubahan
      </button>
    </form>
  </div>

  <div class="card-premium p-6">
    <h3 class="text-lg font-semibold text-slate-900 mb-1">Ubah Peran</h3>
    <p class="text-sm text-slate-500 mb-5">Peran menentukan hak akses pengguna dalam sistem.</p>
    <form action="/auth/users/<%= detailUser.id %>/role" method="POST" class="flex flex-col sm:flex-row gap-3 items-start sm:items-end">
      <div class="w-full sm:flex-1">
        <label for="role-select" class="form-label">Pilih Peran</label>
        <select id="role-select" name="role" class="form-select">
          <option value="admin" <%= detailUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
          <option value="dosen" <%= detailUser.role === 'dosen' ? 'selected' : '' %>>Dosen</option>
        </select>
      </div>
      <button type="submit" class="btn btn-secondary w-full sm:w-auto">Ubah Peran</button>
    </form>
  </div>

  <div class="card-premium p-6">
    <h3 class="text-lg font-semibold text-slate-900 mb-1">Status Akun</h3>
    <p class="text-sm text-slate-500 mb-5">Nonaktifkan akun untuk mencegah pengguna login tanpa menghapus datanya.</p>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-4 rounded-lg bg-slate-50 border border-slate-100">
      <div class="flex items-center gap-3">
        <span class="text-sm font-medium text-slate-700">Status saat ini:</span>
        <% if (detailUser.status === 'aktif') { %>
          <span class="badge-status-aktif">Aktif</span>
        <% } else { %>
          <span class="badge-status-ditolak">Nonaktif</span>
        <% } %>
      </div>
      <form action="/auth/users/<%= detailUser.id %>/status" method="POST" class="w-full sm:w-auto">
        <% if (detailUser.status === 'aktif') { %>
          <input type="hidden" name="status" value="nonaktif">
          <button type="submit" class="w-full sm:w-auto px-4 py-2 border border-amber-500 text-amber-600 bg-amber-50 hover:bg-amber-100 text-sm font-semibold rounded-lg transition-colors" onclick="return confirm('Nonaktifkan akun <%= detailUser.name %>?')">
            Nonaktifkan Akun
          </button>
        <% } else { %>
          <input type="hidden" name="status" value="aktif">
          <button type="submit" class="w-full sm:w-auto px-4 py-2 border border-emerald-500 text-emerald-600 bg-emerald-50 hover:bg-emerald-100 text-sm font-semibold rounded-lg transition-colors" onclick="return confirm('Aktifkan kembali akun <%= detailUser.name %>?')">
            Aktifkan Akun
          </button>
        <% } %>
      </form>
    </div>
  </div>

  
  <div class="card-premium p-6 border-red-200">
    <h3 class="text-lg font-semibold text-red-600 mb-1">Hapus Akun</h3>
    <p class="text-sm text-slate-500 mb-5">
      Tindakan ini <strong class="text-slate-700">tidak dapat dibatalkan</strong>. Akun pengguna dan
      seluruh data terkait akan dihapus secara permanen.
    </p>
    <form action="/auth/users/<%= detailUser.id %>/delete" method="POST">
      <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 text-red-600 border border-red-200 text-sm font-semibold rounded-lg hover:bg-red-100 hover:border-red-300 transition-colors" data-name="<%= detailUser.name %>" onclick="return confirm('Yakin ingin menghapus akun ' + this.dataset.name + '? Tindakan ini tidak dapat dibatalkan.')">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
        Hapus Akun Permanen
      </button>
    </form>
  </div>

</div>

<div class="mt-8">
  <a href="/auth/users" class="btn btn-secondary">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
    Kembali ke Daftar
  </a>
</div>

<%- include('../partials/footer') %>