<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_page-header', {
  title: 'Dashboard',
  subtitle: 'Selamat datang, ' + (user.name || user.email) + '!'
}) %>

<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5 mb-10">
  <% if (stats.totalUsers !== null) { %>
    <div class="card-premium p-6 text-center group cursor-default">
      <div class="mx-auto w-14 h-14 bg-gradient-to-br from-blue-100 to-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-5 shadow-sm border border-blue-100/50 group-hover:scale-110 transition-transform">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </div>
      <h3 class="text-4xl font-black text-slate-900 m-0 tracking-tight"><%= stats.totalUsers %></h3>
      <p class="text-sm font-semibold text-slate-500 mt-2 uppercase tracking-wide">Total Pengguna</p>
    </div>
  <% } %>

  <div class="card-premium p-6 text-center group cursor-default">
    <div class="mx-auto w-14 h-14 bg-gradient-to-br from-indigo-100 to-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-5 shadow-sm border border-indigo-100/50 group-hover:scale-110 transition-transform">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
    </div>
    <h3 class="text-4xl font-black text-slate-900 m-0 tracking-tight"><%= stats.totalPenelitian %></h3>
    <p class="text-sm font-semibold text-slate-500 mt-2 uppercase tracking-wide">Penelitian Saya</p>
  </div>

  <div class="card-premium p-6 text-center group cursor-default">
    <div class="mx-auto w-14 h-14 bg-gradient-to-br from-emerald-100 to-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center mb-5 shadow-sm border border-emerald-100/50 group-hover:scale-110 transition-transform">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    </div>
    <h3 class="text-4xl font-black text-emerald-600 m-0 tracking-tight"><%= stats.aktifPenelitian %></h3>
    <p class="text-sm font-semibold text-slate-500 mt-2 uppercase tracking-wide">Penelitian Aktif</p>
  </div>

  <div class="card-premium p-6 text-center group cursor-default relative">
    <% if (stats.pendingInvites > 0) { %>
      <span class="absolute top-4 right-4 inline-flex items-center justify-center min-w-[1.5rem] h-6 px-2 rounded-full bg-red-500 text-white text-xs font-bold"><%= stats.pendingInvites %></span>
    <% } %>
    <div class="mx-auto w-14 h-14 bg-gradient-to-br from-amber-100 to-amber-50 text-amber-600 rounded-2xl flex items-center justify-center mb-5 shadow-sm border border-amber-100/50 group-hover:scale-110 transition-transform">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </div>
    <h3 class="text-4xl font-black text-slate-900 m-0 tracking-tight"><%= stats.pendingInvites %></h3>
    <p class="text-sm font-semibold text-slate-500 mt-2 uppercase tracking-wide">Undangan Baru</p>
  </div>
</div>

<% if (Array.isArray(pendingInvites) && pendingInvites.length > 0) { %>
  <div class="card-premium p-6 mb-8 border-amber-200 bg-amber-50/40">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4">
      <div>
        <h3 class="text-lg font-bold text-slate-900 m-0">Undangan Menunggu Respon</h3>
        <p class="text-sm text-slate-600 mt-1 mb-0">Anda diundang bergabung ke <%= pendingInvites.length %> penelitian.</p>
      </div>
      <a href="/penelitian/undangan" class="btn btn-gradient btn-sm shrink-0">Lihat Semua Undangan</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <% pendingInvites.slice(0, 2).forEach(function(p) { %>
        <div class="rounded-xl border border-amber-200 bg-white p-4">
          <p class="font-semibold text-slate-900 m-0 mb-1"><%= p.judul %></p>
          <p class="text-xs text-slate-500 m-0">Ketua: <%= p.ketua_name || '-' %></p>
        </div>
      <% }) %>
    </div>
  </div>
<% } %>

<div class="card-premium overflow-hidden mb-8">
  <div class="px-6 py-5 border-b border-slate-100/60 bg-slate-50/30">
    <h3 class="text-xl font-bold text-slate-900 m-0">Selamat Datang</h3>
  </div>
  <div class="p-6">
    <p class="text-slate-600 leading-relaxed mb-0">
      Platform manajemen penelitian FTI untuk mengelola data penelitian, anggota tim, undangan kolaborasi, serta ekspor/impor laporan.
    </p>
  </div>
</div>

<div class="card-premium overflow-hidden">
  <div class="px-6 py-4 border-b border-slate-100/60 bg-slate-50/30">
    <h3 class="text-lg font-bold text-slate-900 m-0">Aksi Cepat</h3>
  </div>
  <div class="p-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
      <a href="/penelitian/my-penelitian" class="btn btn-outline btn-outline-blue w-full">Data Penelitian</a>
      <a href="/penelitian/create" class="btn btn-gradient w-full">Tambah Penelitian</a>
      <a href="/penelitian/undangan" class="btn btn-outline btn-outline-indigo w-full">Undangan</a>
      <a href="/auth/profile" class="btn btn-secondary w-full">Edit Profil</a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
