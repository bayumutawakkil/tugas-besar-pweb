<%- include('../partials/header') %>
<%- include('../partials/_toast-container') %>

<%- include('../partials/_page-header', {
  title: 'Edit Profil',
  subtitle: 'Perbarui informasi akun dan keamanan Anda'
}) %>

<div class="max-w-2xl mx-auto">

  <div class="card-premium overflow-hidden mb-6">
    <div class="form-card-header">
      <h2>Informasi Profil</h2>
      <p>Perbarui nama dan alamat email Anda</p>
    </div>

    <div class="px-6">
      <div class="flex items-center gap-5 py-6 border-b border-slate-100 mb-6">
        <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white text-xl font-bold shrink-0 shadow-sm">
          <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
        </div>
        <div>
          <div class="font-bold text-lg text-slate-900"><%= user.name || 'Pengguna' %></div>
          <div class="text-sm text-slate-500 mb-1"><%= user.email %></div>
          <span class="<%= user.role === 'admin' ? 'badge-role-ketua' : 'badge-role-anggota' %> capitalize"><%= user.role %></span>
        </div>
      </div>

      <form action="/auth/profile" method="POST" id="profileForm" class="pb-6">
        <%- include('../partials/_input', {
          inputType: 'text', inputId: 'name', inputName: 'name',
          inputLabel: 'Nama Lengkap', inputValue: user.name || '',
          inputPlaceholder: 'Nama lengkap Anda', inputRequired: true
        }) %>
        <%- include('../partials/_input', {
          inputType: 'email', inputId: 'email', inputName: 'email',
          inputLabel: 'Alamat Email', inputValue: user.email || '',
          inputPlaceholder: 'email@contoh.com', inputRequired: true
        }) %>

        <div class="form-group">
          <label for="password" class="form-label">Kata Sandi Baru</label>
          <div class="relative">
            <input type="password" id="password" name="password" class="form-input pr-10" placeholder="Minimal 6 karakter" minlength="6">
            <button type="button" onclick="togglePass('password')" tabindex="-1" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>

        <div class="form-group">
          <label for="password_confirm" class="form-label">Konfirmasi Kata Sandi Baru</label>
          <div class="relative">
            <input type="password" id="password_confirm" name="password_confirm" class="form-input pr-10" placeholder="Ulangi kata sandi baru">
            <button type="button" onclick="togglePass('password_confirm')" tabindex="-1" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div id="passMatchMsg" class="form-hint hidden"></div>
        </div>

        <%- include('../partials/_form-actions', {
          submitLabel: 'Simpan Perubahan',
          cancelHref: '/auth/dashboard'
        }) %>
      </form>
    </div>
  </div>

  <div class="card-premium p-5 flex items-start gap-3 border-blue-100 bg-blue-50/50">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-blue-500 shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <div>
      <p class="font-semibold text-sm text-slate-900 m-0">Informasi Keamanan</p>
      <p class="text-sm text-slate-500 mt-1 mb-0">Kosongkan kolom kata sandi jika tidak ingin mengubahnya.</p>
    </div>
  </div>
</div>

<script>
function togglePass(fieldId) {
  const field = document.getElementById(fieldId);
  field.type = field.type === 'password' ? 'text' : 'password';
}
const passField = document.getElementById('password');
const confirmField = document.getElementById('password_confirm');
const matchMsg = document.getElementById('passMatchMsg');
function checkPasswordMatch() {
  const p = passField.value, c = confirmField.value;
  if (!p && !c) { matchMsg.classList.add('hidden'); return; }
  if (!c.length) { matchMsg.classList.add('hidden'); return; }
  matchMsg.classList.remove('hidden');
  matchMsg.textContent = p === c ? '✓ Kata sandi cocok' : '✗ Kata sandi tidak cocok';
  matchMsg.className = 'form-hint ' + (p === c ? 'text-emerald-600' : 'text-red-500');
}
passField.addEventListener('input', checkPasswordMatch);
confirmField.addEventListener('input', checkPasswordMatch);
document.getElementById('profileForm').addEventListener('submit', function(e) {
  if (passField.value && passField.value !== confirmField.value) {
    e.preventDefault();
    matchMsg.classList.remove('hidden');
    matchMsg.textContent = '✗ Konfirmasi kata sandi tidak cocok';
    matchMsg.className = 'form-hint text-red-500';
    confirmField.focus();
    return;
  }
  const btn = this.querySelector('button[type="submit"]');
  btn.disabled = true;
  btn.classList.add('opacity-70');
  btn.innerHTML = '<svg class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg> Menyimpan...';
});
</script>

<%- include('../partials/footer') %>
