<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Halaman Belum Tersedia — Penelitian FTI</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="pnf-body">

  <div class="pnf-card">

    <!-- Illustration -->
    <div class="pnf-illustration">
      <div class="pnf-circle-bg"></div>
      <div class="pnf-icon-wrap">
        <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5"
             stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77
                   a5.5 5.5 0 0 1-7.57 7.57l-6.93 6.93a2.24 2.24 0 0 1-3.16-3.16
                   l6.93-6.93a5.5 5.5 0 0 1 7.57-7.57l-3.77 3.77z"/>
        </svg>
      </div>
    </div>

    <!-- Badge -->
    <div class="badge badge-primary">
      <span class="badge-dot"></span>
      Sedang Dibangun
    </div>

    <!-- Heading & desc -->
    <h1>Halaman Belum Tersedia</h1>
    <p class="text-muted">
      Fitur ini sedang dalam proses pengembangan dan akan segera hadir.
      Tim kami bekerja keras untuk menghadirkannya secepatnya.
    </p>

    <!-- Progress -->
    <div class="pnf-progress-wrap">
      <div class="pnf-progress-label">
        <span>Progress pengembangan</span>
        <span>Segera hadir ✦</span>
      </div>
      <div class="pnf-progress-track">
        <div class="pnf-progress-fill"></div>
      </div>
    </div>

    <!-- Actions -->
    <div class="btn-row">
      <a href="/auth/dashboard" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
          <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
        </svg>
        Ke Dashboard
      </a>
      <a href="javascript:history.back()" class="btn btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2.5"
             stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"/>
          <polyline points="12 19 5 12 12 5"/>
        </svg>
        Kembali
      </a>
    </div>

    <p class="footer-note">
      <a href="/auth/dashboard">Penelitian FTI</a> &mdash; Sistem Informasi Penelitian
    </p>

  </div>

</body>
</html>
