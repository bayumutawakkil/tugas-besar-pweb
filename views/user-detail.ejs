<%- include('partials/header') %>

<!-- Breadcrumb -->
<nav style="font-size:0.85rem; color:var(--color-muted-foreground); margin-bottom:1rem;">
  <a href="/auth/users" style="color:var(--primary); text-decoration:none;">Kelola Pengguna</a>
  &rsaquo; Detail Pengguna
</nav>

<!-- Page Header -->
<div class="page-header" style="margin-bottom:1.5rem;">
  <h1 class="page-title" style="margin:0;">Detail Pengguna</h1>
  <p style="margin:0.25rem 0 0; color:var(--color-muted-foreground);">
    ID #<%= detailUser.id %> &middot; Terdaftar sejak
    <%= detailUser.created_at ? new Date(detailUser.created_at).toLocaleDateString('id-ID', { day:'2-digit', month:'long', year:'numeric' }) : '-' %>
  </p>
</div>

<div style="display:grid; gap:1.25rem; max-width:700px;">

  <!-- Info Akun -->
  <div class="card" style="padding:1.5rem;">
    <h3 style="margin:0 0 1rem; font-size:1rem;">Informasi Akun</h3>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; font-size:0.9rem;">
      <div>
        <div style="color:var(--color-muted-foreground); font-size:0.78rem; margin-bottom:2px;">Nama</div>
        <div style="font-weight:600;"><%= detailUser.name %></div>
      </div>
      <div>
        <div style="color:var(--color-muted-foreground); font-size:0.78rem; margin-bottom:2px;">Email</div>
        <div><%= detailUser.email %></div>
      </div>
      <div>
        <div style="color:var(--color-muted-foreground); font-size:0.78rem; margin-bottom:2px;">Role</div>
        <div>
          <% if (detailUser.role === 'admin') { %>
            <span class="badge badge-blue">Admin</span>
          <% } else if (detailUser.role === 'dosen') { %>
            <span class="badge badge-gray">Dosen</span>
          <% } else { %>
            <span class="badge badge-gray">Anggota</span>
          <% } %>
        </div>
      </div>
      <div>
        <div style="color:var(--color-muted-foreground); font-size:0.78rem; margin-bottom:2px;">Status</div>
        <div>
          <% if (detailUser.status === 'aktif') { %>
            <span class="badge badge-green">Aktif</span>
          <% } else { %>
            <span class="badge badge-red">Nonaktif</span>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Edit Nama & Email -->
  <div class="card" style="padding:1.5rem;">
    <h3 style="margin:0 0 1rem; font-size:1rem;">Edit Nama & Email</h3>
    <form action="/auth/users/<%= detailUser.id %>/edit" method="POST">
      <div class="field">
        <label for="edit-name">Nama</label>
        <input
          id="edit-name"
          type="text"
          name="name"
          value="<%= detailUser.name %>"
          class="input"
          required
        >
      </div>
      <div class="field">
        <label for="edit-email">Email</label>
        <input
          id="edit-email"
          type="email"
          name="email"
          value="<%= detailUser.email %>"
          class="input"
          required
        >
      </div>
      <button type="submit" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/>
          <polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>
        </svg>
        Simpan Perubahan
      </button>
    </form>
  </div>

  <!-- Ubah Role -->
  <div class="card" style="padding:1.5rem;">
    <h3 style="margin:0 0 0.5rem; font-size:1rem;">Ubah Role</h3>
    <p style="margin:0 0 1rem; font-size:0.85rem; color:var(--color-muted-foreground);">
      Role menentukan hak akses pengguna dalam sistem.
    </p>
    <form action="/auth/users/<%= detailUser.id %>/role" method="POST"
          style="display:flex; gap:0.5rem; align-items:flex-end;">
      <div class="field" style="flex:1; margin:0;">
        <label for="role-select">Pilih Role</label>
        <select id="role-select" name="role" class="input">
          <option value="admin"   <%= detailUser.role === 'admin'   ? 'selected' : '' %>>Admin</option>
          <option value="dosen"   <%= detailUser.role === 'dosen'   ? 'selected' : '' %>>Dosen</option>
          <option value="anggota" <%= detailUser.role === 'anggota' ? 'selected' : '' %>>Anggota</option>
        </select>
      </div>
      <button type="submit" class="btn btn-secondary" style="flex-shrink:0;">Ubah Role</button>
    </form>
  </div>

  <!-- Status Akun -->
  <div class="card" style="padding:1.5rem;">
    <h3 style="margin:0 0 0.5rem; font-size:1rem;">Status Akun</h3>
    <p style="margin:0 0 1rem; font-size:0.85rem; color:var(--color-muted-foreground);">
      Nonaktifkan akun untuk mencegah pengguna login tanpa menghapus datanya.
    </p>
    <div style="display:flex; align-items:center; gap:1rem;">
      <div>
        Status saat ini:
        <% if (detailUser.status === 'aktif') { %>
          <span class="badge badge-green">Aktif</span>
        <% } else { %>
          <span class="badge badge-red">Nonaktif</span>
        <% } %>
      </div>
      <form action="/auth/users/<%= detailUser.id %>/status" method="POST" style="display:inline;">
        <% if (detailUser.status === 'aktif') { %>
          <input type="hidden" name="status" value="nonaktif">
          <button type="submit" class="btn btn-secondary"
                  style="border-color:var(--color-warning, #f59e0b); color:var(--color-warning, #f59e0b);"
                  onclick="return confirm('Nonaktifkan akun <%= detailUser.name %>?')">
            Nonaktifkan
          </button>
        <% } else { %>
          <input type="hidden" name="status" value="aktif">
          <button type="submit" class="btn btn-secondary"
                  style="border-color:var(--color-success, #10b981); color:var(--color-success, #10b981);"
                  onclick="return confirm('Aktifkan kembali akun <%= detailUser.name %>?')">
            Aktifkan
          </button>
        <% } %>
      </form>
    </div>
  </div>

  <!-- Hapus Akun -->
  <div class="card" style="padding:1.5rem; border:1px solid #fca5a5;">
    <h3 style="margin:0 0 0.5rem; font-size:1rem; color:#dc2626;">Hapus Akun</h3>
    <p style="margin:0 0 1rem; font-size:0.85rem; color:var(--color-muted-foreground);">
      Tindakan ini <strong>tidak dapat dibatalkan</strong>. Akun pengguna dan
      seluruh data terkait akan dihapus secara permanen.
    </p>
    <form
      action="/auth/users/<%= detailUser.id %>/delete"
      method="POST"
    >
      <button
        type="submit"
        class="btn btn-destructive"
        data-name="<%= detailUser.name %>"
        onclick="return confirm('Yakin ingin menghapus akun ' + this.dataset.name + '? Tindakan ini tidak dapat dibatalkan.')">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/>
          <path d="M10 11v6"/><path d="M14 11v6"/>
          <path d="M9 6V4h6v2"/>
        </svg>
        Hapus Akun Permanen
      </button>
    </form>
  </div>

</div>

<div style="margin-top:1.5rem;">
  <a href="/auth/users" class="btn btn-secondary">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
    </svg>
    Kembali ke Daftar
  </a>
</div>

<%- include('partials/footer') %>