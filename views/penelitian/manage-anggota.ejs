<%- include('../partials/header') %>

<div style="max-width:800px; margin:0 auto;">

  <!-- Breadcrumb -->
  <nav style="font-size:0.85rem; color:var(--color-muted-foreground); margin-bottom:1rem;">
    <a href="/penelitian/my-penelitian" style="color:var(--primary); text-decoration:none;">Data Penelitian</a>
    &rsaquo;
    <a href="/penelitian/<%= penelitian.id %>" style="color:var(--primary); text-decoration:none;">Detail</a>
    &rsaquo; Kelola Anggota
  </nav>

  <!-- Error -->
  <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="alert alert-destructive" style="margin-bottom:1rem;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="12" y1="8" x2="12" y2="12"/>
        <line x1="12" y1="16" x2="12.01" y2="16"/>
      </svg>
      <div><% errors.forEach(e => { %><p style="margin:0;"><%= e %></p><% }) %></div>
    </div>
  <% } %>

  <div class="card" style="padding:1.5rem; margin-bottom:1.25rem;">
    <h2 style="margin:0 0 0.25rem;">Kelola Anggota</h2>
    <p style="margin:0; color:var(--color-muted-foreground);">
      Penelitian: <strong><%= penelitian.judul %></strong>
    </p>
  </div>

  <!-- Form Tambah Anggota -->
  <div class="card" style="padding:1.5rem; margin-bottom:1.25rem;">
    <h3 style="margin:0 0 1rem;">Tambah Anggota</h3>
    <form method="POST" action="/penelitian/<%= penelitian.id %>/anggota/add"
          style="display:flex; gap:0.5rem; align-items:flex-end;">
      <div class="field" style="flex:1; margin:0;">
        <label for="dosen_id">Pilih Dosen</label>
        <select id="dosen_id" name="dosen_id" class="input" required>
          <option value="">-- Pilih Dosen --</option>
          <% availableDosen.forEach(d => { %>
            <option value="<%= d.id %>"><%= d.name %> (<%= d.email %>)</option>
          <% }) %>
        </select>
      </div>
      <button type="submit" class="btn btn-primary" style="flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="8.5" cy="7" r="4"/>
          <line x1="20" y1="8" x2="20" y2="14"/>
          <line x1="23" y1="11" x2="17" y2="11"/>
        </svg>
        Tambahkan
      </button>
    </form>
    <% if (availableDosen.length === 0) { %>
      <p style="margin:0.75rem 0 0; font-size:0.85rem; color:var(--color-muted-foreground);">
        Semua dosen sudah terdaftar di penelitian ini.
      </p>
    <% } %>
  </div>

  <!-- Daftar Anggota -->
  <div class="card" style="padding:1.5rem;">
    <h3 style="margin:0 0 1rem;">Daftar Anggota (<%= anggotaList.length %>)</h3>
    <% if (anggotaList.length === 0) { %>
      <p style="text-align:center; color:var(--color-muted-foreground); padding:1rem 0;">
        Belum ada anggota terdaftar.
      </p>
    <% } else { %>
      <div style="overflow-x:auto;">
        <table class="table" style="width:100%; border-collapse:collapse;">
          <thead>
            <tr>
              <th>Nama</th>
              <th>Email</th>
              <th style="text-align:center;">Peran</th>
              <th style="text-align:center;">Status</th>
              <th style="text-align:center; width:7rem;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% anggotaList.forEach(a => { %>
              <tr>
                <td><%= a.dosen_name || '-' %></td>
                <td style="font-size:0.82rem; color:var(--color-muted-foreground);"><%= a.dosen_email || '-' %></td>
                <td style="text-align:center;">
                  <span class="badge <%= a.role === 'Ketua' ? 'badge-blue' : 'badge-gray' %>">
                    <%= a.role %>
                  </span>
                </td>
                <td style="text-align:center;">
                  <% if (a.status === 'approved') { %>
                    <span class="badge badge-green">Diterima</span>
                  <% } else if (a.status === 'rejected') { %>
                    <span class="badge badge-red">Ditolak</span>
                  <% } else { %>
                    <span class="badge badge-yellow">Menunggu</span>
                  <% } %>
                </td>
                <td style="text-align:center;">
                  <% if (a.role !== 'Ketua') { %>
                    <form method="POST" action="/penelitian/<%= penelitian.id %>/anggota/remove"
                          onsubmit="return confirm('Hapus anggota <%= a.dosen_name %>?')">
                      <input type="hidden" name="dosen_id" value="<%= a.dosen_id %>">
                      <button type="submit" class="btn btn-destructive"
                              style="padding:0.2rem 0.5rem; font-size:0.78rem;">
                        Hapus
                      </button>
                    </form>
                  <% } else { %>
                    <span style="font-size:0.78rem; color:var(--color-muted-foreground);">–</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

</div>

<%- include('../partials/footer') %>
