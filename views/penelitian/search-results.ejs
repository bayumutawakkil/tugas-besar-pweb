<%- include('../partials/header') %>

<!-- Page Header -->
<div class="page-header" style="margin-bottom:1.25rem;">
  <h1 class="page-title" style="margin:0;">Hasil Pencarian</h1>
  <p style="margin:0.25rem 0 0; color:var(--color-muted-foreground);">
    Menampilkan hasil untuk kata kunci:
    <strong>"<%= keyword %>"</strong>
    <% if (scope === 'mine') { %>(hanya penelitian saya)<% } %>
    — ditemukan <strong><%= penelitianList.length %></strong> hasil
  </p>
</div>

<!-- Search Bar (Refine) -->
<div class="card" style="padding:1rem; margin-bottom:1.25rem;">
  <form action="/penelitian/search" method="GET" style="display:flex; gap:0.5rem;">
    <input
      type="text"
      name="q"
      class="input"
      placeholder="Cari ulang..."
      value="<%= keyword %>"
      style="flex:1;"
    >
    <select name="scope" class="input" style="width:auto;">
      <option value="all"  <%= scope === 'all'  ? 'selected' : '' %>>Semua Penelitian</option>
      <option value="mine" <%= scope === 'mine' ? 'selected' : '' %>>Penelitian Saya</option>
    </select>
    <button type="submit" class="btn btn-primary">Cari</button>
    <a href="/penelitian/dashboard" class="btn btn-secondary">Reset</a>
  </form>
</div>

<!-- Results -->
<% if (penelitianList.length === 0) { %>
  <div class="card" style="padding:3rem; text-align:center;">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
         style="margin:0 auto 1rem; color:var(--color-muted-foreground);">
      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
    </svg>
    <p style="color:var(--color-muted-foreground); margin:0;">
      Tidak ada penelitian yang cocok dengan kata kunci
      <strong>"<%= keyword %>"</strong>.
    </p>
    <div style="margin-top:1rem;">
      <a href="/penelitian/dashboard" class="btn btn-secondary">Kembali ke Daftar</a>
    </div>
  </div>
<% } else { %>
  <div class="card">
    <div style="overflow-x:auto;">
      <table class="table" style="width:100%; border-collapse:collapse;">
        <thead>
          <tr>
            <th style="width:3rem; text-align:center;">No</th>
            <th>Judul Penelitian</th>
            <th>Ketua</th>
            <th style="text-align:center;">Tahun</th>
            <th style="text-align:center;">Anggota</th>
            <th style="text-align:center;">Status</th>
            <th style="text-align:center; width:7rem;">Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% penelitianList.forEach((p, i) => { %>
            <tr>
              <td style="text-align:center;"><%= i + 1 %></td>
              <td>
                <a href="/penelitian/<%= p.id %>"
                   style="font-weight:600; color:var(--primary); text-decoration:none;">
                  <!-- Highlight keyword dalam judul -->
                  <%
                    const re = new RegExp('(' + keyword.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
                    const highlighted = p.judul.replace(re, '<mark>$1</mark>');
                  %>
                  <%- highlighted %>
                </a>
              </td>
              <td><%= p.ketua_name || '-' %></td>
              <td style="text-align:center;">
                <%= p.tahun_mulai %>
                <% if (p.tahun_selesai) { %>– <%= p.tahun_selesai %><% } %>
              </td>
              <td style="text-align:center;"><%= p.total_anggota || 0 %></td>
              <td style="text-align:center;">
                <%- include('../partials/_badge-status', { status: p.status }) %>
              </td>
              <td style="text-align:center;">
                <a href="/penelitian/<%= p.id %>" class="btn btn-secondary"
                   style="padding:0.25rem 0.6rem; font-size:0.8rem;">Detail</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<style>
mark {
  background: #FEF08A;
  color: inherit;
  border-radius: 2px;
  padding: 0 2px;
}
</style>

<%- include('../partials/footer') %>
