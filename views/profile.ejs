<%- include('partials/header') %>

<div class="page-header">
  <h1 class="page-title">Edit Profil</h1>
  <p class="page-subtitle">Perbarui informasi akun dan keamanan Anda</p>
</div>

<div style="max-width: 680px; margin: 0 auto;">

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-destructive" style="margin-bottom: var(--space-6); display: flex; align-items: flex-start; gap: var(--space-3);">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="15" y1="9" x2="9" y2="15"></line>
      <line x1="9" y1="9" x2="15" y2="15"></line>
    </svg>
    <span><%= error %></span>
  </div>
  <% } %>

  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success" style="margin-bottom: var(--space-6); display: flex; align-items: flex-start; gap: var(--space-3);">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; margin-top:1px;">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
      <polyline points="22 4 12 14.01 9 11.01"></polyline>
    </svg>
    <span><%= success %></span>
  </div>
  <% } %>

  <div class="card" style="padding: 2em; margin-bottom: var(--space-6);">
    <div class="card-header">
      <h3 class="card-title">Informasi Profil</h3>
      <p class="card-desc" style="color: var(--text-secondary); margin: 4px 0 0 0; font-size: 0.9rem;">Perbarui nama dan alamat email Anda</p>
    </div>

    <div style="display: flex; align-items: center; gap: var(--space-5); padding: var(--space-6) 0; border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-6);">
<div class="profile-avatar">
          <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
      </div>
      <div>
        <div style="font-weight: 700; font-size: 1.1rem; color: var(--text-main);"><%= user.name || 'Pengguna' %></div>
        <div style="color: var(--text-secondary); font-size: 0.9rem;"><%= user.email %></div>
        <span class="badge badge-userrole-<%= user.role === 'admin' ? 'admin' : user.role === 'dosen' ? 'dosen' : 'default' %>" style="text-transform: capitalize;">
  <%= user.role %>
</span>
      </div>
    </div>

    <form action="/auth/profile" method="POST" id="profileForm" class="flex flex-col gap-4">

      <div class="form-group">
        <label for="name" style="display: block; font-weight: 600; margin-bottom: var(--space-2); font-size: 0.9rem;">Nama Lengkap <span style="color: var(--color-destructive);">*</span></label>
        <input
          type="text"
          id="name"
          name="name"
          class="input"
          value="<%= user.name || '' %>"
          placeholder="Nama lengkap Anda"
          required
          style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-background); color: var(--text-main); font-size: 0.95rem; box-sizing: border-box;"
        >
      </div>

      <div class="form-group">
        <label for="email" style="display: block; font-weight: 600; margin-bottom: var(--space-2); font-size: 0.9rem;">Alamat Email <span style="color: var(--color-destructive);">*</span></label>
        <input
          type="email"
          id="email"
          name="email"
          class="input"
          value="<%= user.email || '' %>"
          placeholder="email@contoh.com"
          required
          style="width: 100%; padding: var(--space-3) var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-background); color: var(--text-main); font-size: 0.95rem; box-sizing: border-box;"
        >
      </div>

      <div class="form-group">
        <label for="password" style="display: block; font-weight: 600; margin-bottom: var(--space-2); font-size: 0.9rem;">Password Baru</label>
        <div style="position: relative;">
          <input
            type="password"
            id="password"
            name="password"
            class="input"
            placeholder="Minimal 6 karakter"
            minlength="6"
            style="width: 100%; padding: var(--space-3) var(--space-4); padding-right: 48px; border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-background); color: var(--text-main); font-size: 0.95rem; box-sizing: border-box;"
          >
          <button type="button" onclick="togglePass('password')" tabindex="-1"
            style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--text-secondary); padding: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
      </div>

      <div class="form-group">
        <label for="password_confirm" style="display: block; font-weight: 600; margin-bottom: var(--space-2); font-size: 0.9rem;">Konfirmasi Password Baru</label>
        <div style="position: relative;">
          <input
            type="password"
            id="password_confirm"
            name="password_confirm"
            class="input"
            placeholder="Ulangi password baru"
            style="width: 100%; padding: var(--space-3) var(--space-4); padding-right: 48px; border: 1px solid var(--color-border); border-radius: var(--radius); background: var(--color-background); color: var(--text-main); font-size: 0.95rem; box-sizing: border-box;"
          >
          <button type="button" onclick="togglePass('password_confirm')" tabindex="-1"
            style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--text-secondary); padding: 0;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
          </button>
        </div>
        <div id="passMatchMsg" style="font-size: 0.8rem; margin-top: 4px; display: none;"></div>
      </div>

      <div style="display: flex; gap: var(--space-3); padding-top: var(--space-2);">
        <button type="submit" class="btn btn-primary" id="submitBtn" style="flex: 1;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
            <polyline points="17 21 17 13 7 13 7 21"></polyline>
            <polyline points="7 3 7 8 15 8"></polyline>
          </svg>
          Simpan Perubahan
        </button>
        <a href="/auth/dashboard" class="btn btn-secondary">Batal</a>
      </div>

    </form>
  </div>

  <div class="card" style="padding: 1.5em;">
    <div style="display: flex; align-items: flex-start; gap: var(--space-3);">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0; color: var(--primary); margin-top: 2px;">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="16" x2="12" y2="12"></line>
        <line x1="12" y1="8" x2="12.01" y2="8"></line>
      </svg>
      <div>
        <p style="margin: 0 0 4px 0; font-weight: 600; font-size: 0.9rem;">Informasi Keamanan</p>
        <p style="margin: 0; color: var(--text-secondary); font-size: 0.85rem;">
          Kosongkan jika tidak ingin mengubah password
        </p>
      </div>
    </div>
  </div>

</div>

<script>
function togglePass(fieldId) {
  const field = document.getElementById(fieldId);
  field.type = field.type === 'password' ? 'text' : 'password';
}

// Real-time password match check
const passField = document.getElementById('password');
const confirmField = document.getElementById('password_confirm');
const matchMsg = document.getElementById('passMatchMsg');

function checkPasswordMatch() {
  const p = passField.value;
  const c = confirmField.value;
  if (!p && !c) { matchMsg.style.display = 'none'; return; }
  if (c.length === 0) { matchMsg.style.display = 'none'; return; }
  matchMsg.style.display = 'block';
  if (p === c) {
    matchMsg.textContent = '✓ Password cocok';
    matchMsg.style.color = 'var(--color-success, #22c55e)';
  } else {
    matchMsg.textContent = '✗ Password tidak cocok';
    matchMsg.style.color = 'var(--color-destructive, #ef4444)';
  }
}

passField.addEventListener('input', checkPasswordMatch);
confirmField.addEventListener('input', checkPasswordMatch);

// Loading state on submit
document.getElementById('profileForm').addEventListener('submit', function(e) {
  const p = passField.value;
  const c = confirmField.value;
  if (p && p !== c) {
    e.preventDefault();
    matchMsg.style.display = 'block';
    matchMsg.textContent = '✗ Konfirmasi password tidak cocok';
    matchMsg.style.color = 'var(--color-destructive, #ef4444)';
    confirmField.focus();
    return;
  }
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> <span>Menyimpan...</span>';
});
</script>

<%- include('partials/footer') %>
