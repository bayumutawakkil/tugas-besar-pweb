<%- include('partials/header') %>

<div class="relative overflow-hidden bg-gradient-to-br from-blue-900 via-blue-800 to-indigo-900 text-white rounded-3xl mx-auto max-w-5xl mt-4 mb-10 shadow-2xl shadow-blue-900/20 animate-fade-in">
  <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10 mix-blend-overlay"></div>
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse"></div>
  <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-indigo-500 rounded-full mix-blend-multiply filter blur-3xl opacity-30 animate-pulse" style="animation-delay: 2s;"></div>
  
  <div class="relative px-6 py-14 sm:py-20 lg:px-12 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-blue-100 text-xs font-semibold mb-6 backdrop-blur-sm">
      Fakultas Teknologi Informasi
    </div>
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight mb-6 bg-clip-text text-transparent bg-gradient-to-r from-blue-100 to-white">
      Sistem Informasi Penelitian FTI
    </h1>
    <p class="text-lg sm:text-xl text-blue-100 max-w-2xl mx-auto leading-relaxed mb-8 opacity-90">
      Platform manajemen penelitian modern. Kelola penelitian, anggota tim, dan kolaborasi dengan mudah dan efisien.
    </p>
    <% if (typeof user === 'undefined' || !user) { %>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/auth/register" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-blue-700 font-bold rounded-xl hover:bg-blue-50 transition-all shadow-lg hover:-translate-y-0.5">
        Mulai Sekarang
      </a>
      <a href="/auth/login" class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold rounded-xl border border-white/30 hover:bg-white/20 transition-all backdrop-blur-sm">
        Login
      </a>
    </div>
    <% } %>
  </div>
</div>

<!-- Feature Cards -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto mb-12 px-2 animate-fade-in">
  <div class="card-premium p-6 text-center">
    <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center border border-blue-100">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
      </svg>
    </div>
    <h3 class="font-bold text-slate-900 mb-2">Kelola Penelitian</h3>
    <p class="text-sm text-slate-500 leading-relaxed">Catat, edit, dan pantau seluruh data penelitian dosen FTI dalam satu dashboard.</p>
  </div>
  <div class="card-premium p-6 text-center">
    <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-indigo-50 text-indigo-600 flex items-center justify-center border border-indigo-100">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
    </div>
    <h3 class="font-bold text-slate-900 mb-2">Kolaborasi Tim</h3>
    <p class="text-sm text-slate-500 leading-relaxed">Undang anggota penelitian, kelola peran ketua dan anggota dengan sistem undangan.</p>
  </div>
  <div class="card-premium p-6 text-center">
    <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center border border-emerald-100">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
    </div>
    <h3 class="font-bold text-slate-900 mb-2">Ekspor Data</h3>
    <p class="text-sm text-slate-500 leading-relaxed">Export laporan penelitian ke Excel atau PDF, serta import data dari spreadsheet.</p>
  </div>
</div>

<% if (typeof user === 'undefined' || !user) { %>
<div class="flex justify-center px-4 pb-8">
  <div class="card-premium p-8 w-full max-w-[500px]">
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-50 text-blue-600 mb-4 shadow-sm border border-blue-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
      </div>
      <h2 class="text-2xl font-bold text-slate-900 mb-2">Selamat Datang di Portal</h2>
      <p class="text-slate-500 text-sm">Masuk untuk mengelola data penelitian atau buat akun baru jika belum memiliki akses.</p>
    </div>
    
    <div class="flex flex-col gap-4">
      <a href="/auth/register" class="flex items-center justify-center gap-2 px-6 py-3.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 hover:shadow-lg hover:shadow-blue-600/30 transition-all transform hover:-translate-y-0.5">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="19" y1="8" x2="19" y2="14" /><line x1="22" y1="11" x2="16" y2="11" />
        </svg>
        Daftar Akun Baru
      </a>
      <a href="/auth/login" class="flex items-center justify-center gap-2 px-6 py-3.5 bg-white border-2 border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 hover:border-blue-300 hover:text-blue-700 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" />
        </svg>
        Login ke Akun
      </a>
    </div>
  </div>
</div>
<% } else { %>
<div class="flex justify-center px-4 pb-8">
  <div class="card-premium p-8 w-full max-w-[500px] text-center">
    <h2 class="text-xl font-bold text-slate-900 mb-2">Halo, <%= user.name || 'Pengguna' %>!</h2>
    <p class="text-slate-500 text-sm mb-6">Anda sudah login. Akses dashboard untuk mulai mengelola penelitian.</p>
    <a href="/auth/dashboard" class="btn btn-primary">Buka Dashboard</a>
  </div>
</div>
<% } %>

<%- include('partials/footer') %>
